@page
@model NexoEscolar.Pages.IndexModel
@{
    ViewData["Title"] = "Inicio";
    ViewData["SeoDescription"] = Model.Hero.Subheadline;
}

@* ─── HERO ──────────────────────────────────────────────────────────────── *@
<section id="hero" class="ne-hero d-flex align-items-center">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6" data-aos="fade-up">
                <h1 class="ne-hero__headline">@Model.Hero.Headline</h1>
                <p class="ne-hero__sub mt-3">@Model.Hero.Subheadline</p>
                <a href="@Model.Hero.CtaHref" class="btn btn-amber btn-lg mt-4 px-5">@Model.Hero.CtaLabel</a>
            </div>
            <div class="col-lg-6 d-flex justify-content-center gap-4 flex-wrap" data-aos="fade-up" data-aos-delay="150">
                @* Dashboard card *@
                <div class="glass-card p-4 parallax-dash ne-hero__mock-card" style="min-width:220px;">
                    <div class="text-white-50 small mb-3">
                        <i class="bi bi-speedometer2 me-1" style="color:var(--ne-teal)"></i>Panel Directivo
                    </div>
                    @foreach (var chip in Model.Hero.DashboardChips)
                    {
                        <div class="ne-chip d-flex justify-content-between align-items-center mb-2">
                            <span class="text-white-50 small">@chip.Label</span>
                            <span class="fw-bold" style="color:var(--ne-teal)">@chip.Value</span>
                        </div>
                    }
                </div>
                @* Phone frame *@
                <div class="phone-frame parallax-phone d-flex flex-column align-items-center justify-content-center">
                    <div class="ne-notif-card mb-3">
                        <i class="bi bi-bell-fill me-2" style="color:var(--ne-teal)"></i>
                        <span class="text-white small">@Model.Hero.PhoneNotification</span>
                    </div>
                    <div class="text-white-50 small mt-2">
                        <i class="bi bi-android2 me-1"></i>Nexo Escolar App
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ─── PROBLEMA ───────────────────────────────────────────────────────────── *@
<section id="problema" class="py-6">
    <div class="container">
        <h2 class="ne-section-title text-center mb-5" data-aos="fade-up">@Model.Problema.Headline</h2>
        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var (card, i) in Model.Problema.Cards.Select((c, i) => (c, i)))
            {
                <div class="col" data-aos="fade-up" data-aos-delay="@(i * 80)">
                    <div class="glass-card pain-card p-4 h-100">
                        <i class="bi bi-@card.Icon ne-icon-teal mb-3 d-block fs-3"></i>
                        <h5 class="fw-bold text-white mb-2">@card.Title</h5>
                        <p class="text-white-50 mb-0 small">@card.Body</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@* ─── FUNCIONES ──────────────────────────────────────────────────────────── *@
<section id="funciones" class="py-6">
    <div class="container">
        <h2 class="ne-section-title text-center mb-2" data-aos="fade-up">Funciones que transforman la gestión escolar</h2>
        <p class="text-center text-white-50 mb-5" data-aos="fade-up" data-aos-delay="80">Todo lo que necesita tu colegio, en una sola plataforma.</p>
        <div class="bento-grid" data-aos="fade-up" data-aos-delay="120">
            @foreach (var card in Model.FeatureCards)
            {
                var spanClass = card.Span switch
                {
                    "large"  => "bento-large",
                    "medium" => "bento-medium",
                    _        => "bento-small"
                };
                <div class="glass-card bento-card @spanClass p-5">
                    <i class="bi bi-@card.Icon ne-icon-teal mb-3 d-block fs-2"></i>
                    <h5 class="fw-bold text-white mb-2">@card.Title</h5>
                    <p class="text-white-50 small mb-0">@card.Description</p>
                </div>
            }
        </div>
    </div>
</section>

@* ─── BENEFICIOS ─────────────────────────────────────────────────────────── *@
<section id="beneficios" class="py-6">
    <div class="container">
        <h2 class="ne-section-title text-center mb-2" data-aos="fade-up">@Model.Beneficios.Headline</h2>
        <p class="text-center text-white-50 mb-5" data-aos="fade-up" data-aos-delay="80">@Model.Beneficios.Subheadline</p>

        @* Desktop: SVG hub *@
        <div class="hub-wrapper d-none d-md-block" data-aos="fade-up" data-aos-delay="120">
            <div class="hub-inner position-relative">
                @* Central node *@
                <div class="hub-center">
                    <div class="hub-pulse-ring"></div>
                    <div class="hub-node-center">
                        <span class="fw-bold" style="color:var(--ne-teal)">Nexo</span>
                    </div>
                </div>
                @* SVG connector lines *@
                <svg class="hub-svg" viewBox="0 0 600 300" xmlns="http://www.w3.org/2000/svg">
                    <line x1="300" y1="150" x2="80"  y2="80"  stroke="rgba(0,201,177,0.3)" stroke-width="1.5" stroke-dasharray="6,4"/>
                    <line x1="300" y1="150" x2="300" y2="40"  stroke="rgba(0,201,177,0.3)" stroke-width="1.5" stroke-dasharray="6,4"/>
                    <line x1="300" y1="150" x2="520" y2="80"  stroke="rgba(0,201,177,0.3)" stroke-width="1.5" stroke-dasharray="6,4"/>
                </svg>
                @* Satellite nodes *@
                @foreach (var (role, i) in Model.Beneficios.Roles.Select((r, i) => (r, i)))
                {
                    var positions = new[] { "hub-node--left", "hub-node--top", "hub-node--right" };
                    <div class="hub-node-wrap @positions[i]">
                        <div class="hub-node hub-sat" tabindex="0">
                            <i class="bi bi-@role.Icon ne-icon-teal d-block mb-1 fs-4"></i>
                            <span class="fw-semibold text-white small">@role.Label</span>
                        </div>
                        <div class="hub-panel glass-card p-4">
                            <h6 class="fw-bold mb-2" style="color:var(--ne-teal)">@role.Label</h6>
                            <ul class="list-unstyled mb-0">
                                @foreach (var b in role.Benefits)
                                {
                                    <li class="text-white-50 small mb-1"><i class="bi bi-check2-circle me-2" style="color:var(--ne-teal)"></i>@b</li>
                                }
                            </ul>
                        </div>
                    </div>
                }
            </div>
        </div>

        @* Mobile: Bootstrap Tabs *@
        <div class="d-md-none" data-aos="fade-up">
            <ul class="nav nav-tabs ne-tabs mb-4" id="benefTab" role="tablist">
                @foreach (var (role, i) in Model.Beneficios.Roles.Select((r, i) => (r, i)))
                {
                    <li class="nav-item flex-fill" role="presentation">
                        <button class="nav-link w-100 @(i == 0 ? "active" : "")"
                                id="tab-@role.Id"
                                data-bs-toggle="tab"
                                data-bs-target="#panel-@role.Id"
                                type="button" role="tab">
                            <i class="bi bi-@role.Icon me-1"></i>@role.Label
                        </button>
                    </li>
                }
            </ul>
            <div class="tab-content">
                @foreach (var (role, i) in Model.Beneficios.Roles.Select((r, i) => (r, i)))
                {
                    <div class="tab-pane fade @(i == 0 ? "show active" : "")"
                         id="panel-@role.Id" role="tabpanel">
                        <div class="glass-card p-4">
                            <ul class="list-unstyled mb-0">
                                @foreach (var b in role.Benefits)
                                {
                                    <li class="text-white-50 mb-2"><i class="bi bi-check2-circle me-2" style="color:var(--ne-teal)"></i>@b</li>
                                }
                            </ul>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@* ─── APP SHOWCASE ───────────────────────────────────────────────────────── *@
<section id="app" class="py-6">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6" data-aos="fade-up">
                <h2 class="ne-section-title mb-3">@Model.App.Headline</h2>
                <p class="text-white-50 mb-4">@Model.App.Subheadline</p>
                <ul class="list-unstyled">
                    @foreach (var h in Model.App.Highlights)
                    {
                        <li class="mb-2 text-white">
                            <i class="bi bi-check-circle-fill me-2" style="color:var(--ne-teal)"></i>@h
                        </li>
                    }
                </ul>
            </div>
            <div class="col-lg-6 d-flex justify-content-center" data-aos="fade-up" data-aos-delay="120">
                <div class="phone-frame">
                    @foreach (var notif in Model.App.Notifications)
                    {
                        var accentColor = notif.Accent == "amber" ? "var(--ne-amber)" : "var(--ne-teal)";
                        <div class="ne-notif-card mb-3" style="border-left:3px solid @accentColor">
                            <div class="fw-semibold text-white small">@notif.Title</div>
                            <div class="text-white-50 small">@notif.Body</div>
                        </div>
                    }
                    <div class="text-center mt-3">
                        <i class="bi bi-android2 me-1" style="color:var(--ne-teal)"></i>
                        <span class="text-white-50 small">Disponible para Android</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ─── TRUST ──────────────────────────────────────────────────────────────── *@
<section id="trust" class="py-6">
    <div class="container">
        <h2 class="ne-section-title text-center mb-5" data-aos="fade-up">@Model.Trust.Headline</h2>
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var (block, i) in Model.Trust.Blocks.Select((b, i) => (b, i)))
            {
                <div class="col" data-aos="fade-up" data-aos-delay="@(i * 80)">
                    <div class="trust-block glass-card p-4 h-100 text-center">
                        <i class="bi bi-@block.Icon ne-icon-teal d-block mb-3 fs-1"></i>
                        <h5 class="fw-bold text-white mb-2">@block.Title</h5>
                        <p class="text-white-50 small mb-0">@block.Body</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@* ─── DEMO FORM ──────────────────────────────────────────────────────────── *@
<section id="demo" class="py-6">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7" data-aos="fade-up">
                <div class="glass-card demo-card p-5">
                    <h2 class="ne-section-title mb-2 text-center">Solicita tu demo gratuito</h2>
                    <p class="text-center text-white-50 mb-4 small">Sin compromiso. Sin tarjeta de crédito.</p>

                    @if (Model.FormSuccess)
                    {
                        <div class="alert alert-success text-center fw-semibold" role="alert"
                             style="background:rgba(0,201,177,0.15);border-color:var(--ne-teal);color:var(--ne-teal);">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            ¡Gracias! Te contactamos en menos de 24 horas hábiles.
                        </div>
                    }
                    else
                    {
                        <form method="post" novalidate>
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <label class="form-label text-white-50 small" for="NombreCompleto">Nombre completo</label>
                                <input asp-for="Form.NombreCompleto" id="NombreCompleto"
                                       class="form-control ne-input" placeholder="María García" />
                                <span asp-validation-for="Form.NombreCompleto" class="text-danger small"></span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-white-50 small" for="NombreColegio">Nombre del colegio</label>
                                <input asp-for="Form.NombreColegio" id="NombreColegio"
                                       class="form-control ne-input" placeholder="Colegio San José" />
                                <span asp-validation-for="Form.NombreColegio" class="text-danger small"></span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-white-50 small" for="CorreoInstitucional">Correo institucional</label>
                                <input asp-for="Form.CorreoInstitucional" id="CorreoInstitucional"
                                       type="email" class="form-control ne-input" placeholder="direccion@colegio.edu" />
                                <span asp-validation-for="Form.CorreoInstitucional" class="text-danger small"></span>
                            </div>
                            <div class="mb-4">
                                <label class="form-label text-white-50 small" for="WhatsApp">WhatsApp</label>
                                <input asp-for="Form.WhatsApp" id="WhatsApp"
                                       type="tel" class="form-control ne-input" placeholder="+57 300 000 0000" />
                                <span asp-validation-for="Form.WhatsApp" class="text-danger small"></span>
                            </div>
                            <button type="submit" class="btn btn-amber w-100 py-3 fw-bold">
                                Quiero mi demo
                            </button>
                            <p class="text-center text-white-50 small mt-2 mb-0">
                                Te contactamos en menos de 24 horas hábiles.
                            </p>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

@* ─── FAQ ────────────────────────────────────────────────────────────────── *@
<section id="faq" class="py-6">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <h2 class="ne-section-title text-center mb-5" data-aos="fade-up">Preguntas frecuentes</h2>
                <div class="accordion ne-accordion" id="faqAccordion" data-aos="fade-up" data-aos-delay="80">
                    @foreach (var (item, i) in Model.FaqItems.Select((f, i) => (f, i)))
                    {
                        var headingId = $"faqH{i}";
                        var collapseId = $"faqC{i}";
                        <div class="accordion-item glass-card mb-3 border-0">
                            <h3 class="accordion-header" id="@headingId">
                                <button class="accordion-button @(i == 0 ? "" : "collapsed") ne-accordion-btn"
                                        type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#@collapseId"
                                        aria-expanded="@(i == 0 ? "true" : "false")"
                                        aria-controls="@collapseId">
                                    @item.Question
                                </button>
                            </h3>
                            <div id="@collapseId" class="accordion-collapse collapse @(i == 0 ? "show" : "")"
                                 aria-labelledby="@headingId" data-bs-parent="#faqAccordion">
                                <div class="accordion-body text-white-50 small">
                                    @item.Answer
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

@* ─── FOOTER ─────────────────────────────────────────────────────────────── *@
<footer id="footer" class="ne-footer py-5">
    <div class="container text-center">
        <div class="ne-brand mb-3">
            <span class="ne-brand-nexo fs-4">Nexo</span><span class="ne-brand-escolar fs-4">Escolar</span>
        </div>
        <p class="text-white-50 mb-2">@Model.Footer.Tagline</p>
        <p class="text-white-50 small mb-0">@Model.Footer.Copyright</p>
    </div>
</footer>
