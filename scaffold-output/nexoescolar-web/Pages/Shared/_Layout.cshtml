<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="@(string.IsNullOrEmpty(Context.Request.PathBase.Value) ? "/" : $"{Context.Request.PathBase.Value.TrimEnd('/')}/")" />
    <title>@ViewData["Title"] - Nexo Escolar</title>
    <meta name="description" content="@(ViewData["SeoDescription"] ?? "Nexo Escolar — Plataforma de Gestión Escolar para K-12")" />

    <!-- Open Graph -->
    <meta property="og:title" content="@(ViewData["Title"]) - Nexo Escolar" />
    <meta property="og:description" content="@(ViewData["SeoDescription"] ?? "Nexo Escolar — Plataforma de Gestión Escolar para K-12")" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />

    <!-- Canonical -->
    <link rel="canonical" href="https://nexoescolar.com/" />

    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" crossorigin="anonymous" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />

    <!-- AOS.js -->
    <link rel="stylesheet" href="https://unpkg.com/aos@2.3.4/dist/aos.css" crossorigin="anonymous" />

    <!-- Plus Jakarta Sans (Google Fonts) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet" />

    <!-- Site CSS (design tokens + custom classes) -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@graph": [
        {
          "@@type": "Organization",
          "name": "Nexo Escolar",
          "url": "https://nexoescolar.com",
          "description": "Plataforma de gestión escolar para colegios K-12 que conecta directivos, docentes y familias."
        },
        {
          "@@type": "WebSite",
          "name": "Nexo Escolar",
          "url": "https://nexoescolar.com",
          "inLanguage": "es"
        }
      ]
    }
    </script>
</head>
<body>

    <!-- NAVBAR -->
    <nav id="navbar" class="navbar navbar-expand-lg fixed-top ne-navbar">
        <div class="container">
            <a class="navbar-brand ne-brand" href="#hero">
                <span class="ne-brand-nexo">Nexo</span><span class="ne-brand-escolar">Escolar</span>
            </a>
            <button class="navbar-toggler border-0" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarMain"
                    aria-controls="navbarMain" aria-expanded="false" aria-label="Abrir menú">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav ms-auto align-items-center gap-1">
                    <li class="nav-item"><a class="nav-link" href="#funciones">Funciones</a></li>
                    <li class="nav-item"><a class="nav-link" href="#beneficios">Beneficios</a></li>
                    <li class="nav-item"><a class="nav-link" href="#app">App</a></li>
                    <li class="nav-item ms-2">
                        <a class="btn btn-amber btn-sm px-3" href="#demo">Quiero mi demo</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- PAGE CONTENT -->
    <main>
        @RenderBody()
    </main>

    <!-- Bootstrap JS Bundle (Accordion + Tabs + Navbar) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>

    <!-- AOS.js -->
    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js" crossorigin="anonymous"></script>
    <script>AOS.init({ once: true, duration: 700, offset: 80 });</script>

    <!-- Navbar scroll behaviour: transparent → navy -->
    <script>
    (function () {
        var nav = document.getElementById('navbar');
        function updateNav() {
            if (window.scrollY > 40) {
                nav.classList.add('ne-navbar--scrolled');
            } else {
                nav.classList.remove('ne-navbar--scrolled');
            }
        }
        window.addEventListener('scroll', updateNav, { passive: true });
        updateNav();
    })();
    </script>

    <!-- Mouse-parallax for Hero section -->
    <script>
    (function () {
        var phone = document.querySelector('.parallax-phone');
        var dash  = document.querySelector('.parallax-dash');
        if (!phone || !dash) return;
        document.addEventListener('mousemove', function (e) {
            var cx = window.innerWidth / 2;
            var cy = window.innerHeight / 2;
            var dx = (e.clientX - cx) / cx;
            var dy = (e.clientY - cy) / cy;
            phone.style.transform = 'translate(' + (dx * 8) + 'px, ' + (dy * 8) + 'px)';
            dash.style.transform  = 'translate(' + (dx * 4) + 'px, ' + (dy * 4) + 'px)';
        });
    })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
