{
  "inputs": [
    {
      "id": "github-pat",
      "type": "promptString",
      "description": "GitHub Personal Access Token (scope: repo, workflow)",
      "password": true
    }
  ],
  "servers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${input:github-pat}"
      }
    }
  }
}
